# Clerk — https://dashboard.clerk.com → API Keys (enable Google/GitHub/etc. under SSO connections)
PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Turso — https://turso.tech (create a database; use token for hosted, omit for file URLs)
# Local SQLite file (no token):
#   TURSO_DATABASE_URL=file:./local.db
# Hosted Turso:
#   TURSO_DATABASE_URL=libsql://your-db.turso.io
#   TURSO_AUTH_TOKEN=...
#
# Production (Cloudflare Pages): use `libsql://…` only — `file:` does not work on the edge.
TURSO_DATABASE_URL=file:./local.db
TURSO_AUTH_TOKEN=

# Set to "true" to bypass Clerk and use a fixed dev user (local only; remove for production).
SKIP_AUTH=
# Set to "true" to force Pro features in the app for local testing.
FORCE_PRO=

#
# --- Cloudflare Pages (project `spirare`) — runtime env for the deployed worker ---
#
# Astro reads these from the Pages/Worker `env` at request time (dashboard or CLI below).
# Dashboard: Workers & Pages → spirare → Settings → Environment variables → Production
#   · Toggle "Encrypt" for sensitive values (same as `wrangler pages secret`).
#
# CLI (from repo root; prompts for value). Use Pages, not Worker secrets:
#   npx wrangler pages secret put CLERK_SECRET_KEY --project-name spirare
#   npx wrangler pages secret put TURSO_AUTH_TOKEN --project-name spirare
#   npx wrangler pages secret put STRIPE_SECRET_KEY --project-name spirare
#   npx wrangler pages secret put STRIPE_WEBHOOK_SECRET --project-name spirare
#
# Plain variables (same dashboard UI, leave Encrypt off — or use secret put for any key):
#   PUBLIC_CLERK_PUBLISHABLE_KEY, TURSO_DATABASE_URL, STRIPE_PRICE_PRO_MONTHLY, STRIPE_PRICE_PRO_LIFETIME
#
# Bulk encrypted secrets from a local KEY=VALUE file (never commit this file):
#   npx wrangler pages secret bulk ./cf-pages.secrets.env --project-name spirare
#
# Bindings (not env vars): Settings → Functions → KV namespaces → name the binding SESSION
#   (must match wrangler.jsonc). Add https://your-domain in Clerk → Domains.
#
# If the Clerk browser widget misbehaves after deploy, the publishable key must also be present
# at `npm run build:pages` time (e.g. GitHub Actions secret) so the client bundle embeds it.
#
# Build: `npm run build:pages` writes dist/cf-pages plus a Pages-only wrangler.json (nodejs_compat).
# Deploy: `npm run deploy` clears .wrangler then runs `wrangler pages deploy .` from dist/cf-pages.

# Stripe — https://dashboard.stripe.com/apikeys (secret key, server only)
# Create Products/Prices: $1.99/mo subscription and $99 one-time lifetime.
# Webhooks: endpoint `https://spirare.io/api/stripe/webhook` (or your domain); subscribe at least to
# `checkout.session.completed` and `customer.subscription.deleted`.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_LIFETIME=
