{
  "name": "spirare",
  "type": "module",
  "version": "0.0.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mcmadafly/breathe.git"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:pages": "astro build && node scripts/cloudflare-pages-bundle.mjs",
    "deploy": "npm run build:pages && rm -rf .wrangler dist/cf-pages/.wrangler && sh -c 'cd dist/cf-pages && wrangler pages deploy . --project-name=${CLOUDFLARE_PAGES_PROJECT:-breathe}'",
    "cf:whoami": "npx wrangler whoami",
    "deploy:worker": "astro build && wrangler deploy",
    "preview": "astro preview",
    "preview:worker": "wrangler dev",
    "astro": "astro",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:push:force": "drizzle-kit push --force",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:component": "vitest run tests/component",
    "test:e2e": "node tests/e2e/prepare-e2e.mjs && playwright test",
    "test:e2e:ui": "node tests/e2e/prepare-e2e.mjs && playwright test --ui"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.3.0",
    "@astrojs/react": "^5.0.4",
    "@clerk/astro": "^3.1.0",
    "@clerk/localizations": "^4.5.8",
    "@clerk/ui": "^1.7.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/manrope": "^5.2.8",
    "@libsql/client": "^0.17.3",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.2.1",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.14.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "shadcn": "^4.6.0",
    "sonner": "^2.0.7",
    "stripe": "^22.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/canvas-confetti": "^1.9.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "happy-dom": "^20.0.11",
    "vitest": "^4.1.5",
    "wrangler": "^4.50.0"
  }
}
