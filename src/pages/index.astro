---
import { TODO_BOARD_EXPAND_SHELL_CHARS } from '@/lib/todo-limits';
import { WelcomeBanner } from '@/components/welcome-banner';
import { TodoBoardIsland, type TodoListRow, type TodoRow } from '@/components/todo-board-island';
import { listTodoListsForUser } from '@/lib/db/todo-lists';
import { listTodosForUser } from '@/lib/db/todos';

import BaseLayout from '../layouts/BaseLayout.astro';

const session = Astro.locals.session!;

let initialLists: TodoListRow[] = [];
let initialTodos: TodoRow[] = [];
let todoBoardInitiallyWide = false;
let initialTodoDataFailed = false;

try {
  const listRows = await listTodoListsForUser(session.user.id);
  initialLists = listRows.map((r) => ({
    id: r.id,
    userId: r.userId,
    name: r.name,
    position: r.position,
    createdAt: r.createdAt,
    updatedAt: r.updatedAt,
  }));

  const rows = await listTodosForUser(session.user.id);
  initialTodos = rows.map((r) => ({
    id: r.id,
    userId: r.userId,
    title: r.title,
    body: r.body ?? '',
    listId: r.listId ?? '',
    position: r.position ?? 0,
    done: r.done,
    createdAt: r.createdAt,
    updatedAt: r.updatedAt,
  }));

  todoBoardInitiallyWide = rows.some(
    (r) => r.title.length + (r.body?.length ?? 0) > TODO_BOARD_EXPAND_SHELL_CHARS,
  );
} catch (err) {
  const hint =
    err instanceof Error
      ? err.cause instanceof Error
        ? err.cause.message
        : err.message
      : String(err);
  console.warn(`[index] todo SSR load skipped: ${hint}`);
  initialTodoDataFailed = true;
}

const isPro = Astro.locals.isPro;
const isAnonymous = Astro.locals.isAnonymous;
---

<BaseLayout
  title="Breathe"
  session={session}
  isPro={isPro}
  isAnonymous={isAnonymous}
  wideContent
  adaptiveShell
  todoBoardInitiallyWide={todoBoardInitiallyWide}
>
  <WelcomeBanner client:only="react" />
  <TodoBoardIsland
    client:only="react"
    initialTodos={initialTodos}
    initialLists={initialLists}
    isPro={isPro}
    isAnonymous={isAnonymous}
    initialTodoDataFailed={initialTodoDataFailed}
  />
</BaseLayout>
