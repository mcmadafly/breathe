---
import '../styles/global.css';

import type { Session } from '@auth/core/types';

import { ThemeToggle } from '@/components/theme-toggle';
import { TAECHO_SITE_URL } from '@/lib/site';
import { Toaster } from '@/components/ui/sonner';
import { UserMenu } from '@/components/user-menu';

interface Props {
  title?: string;
  session?: Session | null;
  /** When `false`, show an Upgrade control (pass from authenticated routes). */
  isPro?: boolean;
}

const { title = 'Scribbbles', session = null, isPro } = Astro.props;

const skipAuth = import.meta.env.SKIP_AUTH === 'true';
const homeHref = skipAuth ? '/app' : session?.user ? '/app' : '/';
const showUpgrade = isPro === false;
---

<!doctype html>
<html lang="en" suppressHydrationWarning>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="A calm place for quick todos." />
    <meta name="theme-color" content="#fafafa" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <title>{title}</title>
    <script is:inline>
      (function () {
        const t = localStorage.getItem('theme');
        const dark =
          t === 'dark' ||
          (t !== 'light' && window.matchMedia('(prefers-color-scheme: dark)').matches);
        document.documentElement.classList.toggle('dark', dark);
      })();
    </script>
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', function () {
          navigator.serviceWorker.register('/sw.js');
        });
      }
    </script>
  </head>
  <body class="bg-background text-foreground flex min-h-screen flex-col antialiased">
    <header
      class="border-border/80 bg-background/80 supports-backdrop-filter:bg-background/60 sticky top-0 z-10 border-b backdrop-blur"
    >
      <div class="mx-auto flex h-12 max-w-3xl items-center justify-between gap-3 px-3">
        <a href={homeHref} class="font-heading text-lg font-semibold tracking-tight hover:opacity-90">
          Scribbbles
        </a>
        <div class="flex items-center gap-2">
          {
            showUpgrade ? (
              <a
                href="/upgrade"
                class="focus-visible:ring-ring inline-flex h-9 shrink-0 items-center justify-center rounded-lg bg-[#E65124] px-3 text-xs font-semibold text-white shadow-sm outline-none transition-colors hover:bg-[#c43d18] focus-visible:ring-2 focus-visible:ring-offset-2 dark:hover:bg-[#ff6a35]"
              >
                Upgrade
              </a>
            ) : null
          }
          <ThemeToggle client:load />
          {
            session?.user && !skipAuth ? (
              <UserMenu
                client:load
                name={session.user.name}
                email={session.user.email}
                image={session.user.image}
              />
            ) : null
          }
        </div>
      </div>
    </header>
    <main class="mx-auto w-full max-w-3xl flex-1 px-3 py-5 sm:py-6">
      <slot />
    </main>
    <footer
      class="border-border/80 text-muted-foreground mt-auto border-t py-5 text-center text-xs leading-relaxed"
    >
      <div class="mx-auto max-w-3xl px-3">
        <p>
          scribbbles is a product made by{' '}
          <a
            href={TAECHO_SITE_URL}
            class="text-foreground font-medium underline decoration-neutral-400/80 underline-offset-2 hover:opacity-90"
            rel="noopener noreferrer"
            target="_blank"
          >
            Taecho
          </a>
          .{' '}
          <a
            href="/license"
            class="text-foreground font-medium underline decoration-neutral-400/80 underline-offset-2 hover:opacity-90"
          >
            MIT License
          </a>
          .
        </p>
      </div>
    </footer>
    <Toaster client:load />
  </body>
</html>
