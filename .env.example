# Clerk — https://dashboard.clerk.com → API Keys (enable Google/GitHub/etc. under SSO connections)
PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Turso — https://turso.tech (create a database; use token for hosted, omit for file URLs)
# Local SQLite file (no token):
#   TURSO_DATABASE_URL=file:./local.db
# Hosted Turso:
#   TURSO_DATABASE_URL=libsql://your-db.turso.io
#   TURSO_AUTH_TOKEN=...
#
# Production (Cloudflare Workers): use `libsql://…` only — `file:` does not work on the edge.
# Set vars in the Cloudflare dashboard (Workers → spirare → Settings → Variables) or
# `wrangler secret put TURSO_AUTH_TOKEN`. Deploy: `npm run deploy`.
TURSO_DATABASE_URL=file:./local.db
TURSO_AUTH_TOKEN=

# Set to "true" to bypass Clerk and use a fixed dev user (local only; remove for production).
SKIP_AUTH=
# Set to "true" to force Pro features in the app for local testing.
FORCE_PRO=

# spirare.io production (Cloudflare Workers): add https://spirare.io in Clerk → configure → Domains.
# In Cloudflare: Workers & Pages → spirare → Custom domains → spirare.io

# Stripe — https://dashboard.stripe.com/apikeys (secret key, server only)
# Create Products/Prices: $1.99/mo subscription and $99 one-time lifetime.
# Webhooks: endpoint `https://spirare.io/api/stripe/webhook` (or your domain); subscribe at least to
# `checkout.session.completed` and `customer.subscription.deleted`.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_LIFETIME=
