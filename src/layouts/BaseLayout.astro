---
import '../styles/global.css';

import type { AppSession } from '@/lib/auth/session';

import { SiteHeader } from '@/components/site-header';
import { BREATHE_GITHUB_REPO_URL, SITE_DESCRIPTION, TAECHO_SITE_URL } from '@/lib/site';
import { Toaster } from '@/components/ui/sonner';

interface Props {
  title?: string;
  session?: AppSession | null;
  /** Pass through for header: Pro badge vs Upgrade link. */
  isPro?: boolean;
  /** Cookie-backed anonymous user — header shows Sign in instead of account menu. */
  isAnonymous?: boolean;
  /** When `false`, hide the sticky site header (e.g. marketing home). */
  showHeader?: boolean;
  /** Wider main column for dense UIs (e.g. todo board + upgrade). */
  wideContent?: boolean;
  /** Home only: narrow shell on desktop until todos are long; widened client-side from TodoBoard. */
  adaptiveShell?: boolean;
  /** SSR hint when `adaptiveShell`: any todo already exceeds `TODO_BOARD_EXPAND_SHELL_CHARS`. */
  todoBoardInitiallyWide?: boolean;
}

const {
  title = 'Breathe',
  session = null,
  isPro,
  isAnonymous = false,
  showHeader = true,
  wideContent = false,
  adaptiveShell = false,
  todoBoardInitiallyWide = false,
} = Astro.props;

const skipAuth = import.meta.env.SKIP_AUTH === 'true';
const homeHref = '/';
const isProMember = isPro === true;
---

<!doctype html>
<html
  lang="en"
  suppressHydrationWarning
  class:list={[adaptiveShell && 'todo-board-page', adaptiveShell && todoBoardInitiallyWide && 'todo-board-wide']}
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={SITE_DESCRIPTION} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={SITE_DESCRIPTION} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={SITE_DESCRIPTION} />
    <meta name="theme-color" content="#fafafa" />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <title>{title}</title>
    <script is:inline>
      (function () {
        const t = localStorage.getItem('theme');
        const dark =
          t === 'dark' ||
          (t !== 'light' && window.matchMedia('(prefers-color-scheme: dark)').matches);
        document.documentElement.classList.toggle('dark', dark);
      })();
    </script>
    {!adaptiveShell ? (
      <script is:inline>
        document.documentElement.classList.remove('zen-mode');
      </script>
    ) : null}
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', function () {
          navigator.serviceWorker.register('/sw.js');
        });
      }
    </script>
    <script is:inline>
      (function () {
        var KEY = 'scribbbles-dev-chunk-reload';
        function maybeReload(reason) {
          try {
            if (sessionStorage.getItem(KEY)) return;
            sessionStorage.setItem(KEY, '1');
            console.warn('[scribbbles] Recovering from stale dev chunk:', reason);
            window.location.reload();
          } catch (_) {}
        }
        window.addEventListener('unhandledrejection', function (ev) {
          var r = ev.reason;
          var msg = r && r.message ? String(r.message) : String(r || '');
          if (
            msg.indexOf('Failed to fetch dynamically imported module') !== -1 ||
            msg.indexOf('Importing a module script failed') !== -1 ||
            msg.indexOf('error loading dynamically imported module') !== -1
          ) {
            ev.preventDefault();
            maybeReload(msg.slice(0, 120));
          }
        });        
        window.addEventListener(
          'error',
          function (ev) {
            var t = ev.target;
            if (!t || t === window) return;
            var src = t.src || t.href;
            if (!src || typeof src !== 'string') return;
            if (src.indexOf('/@vite/') !== -1 || src.indexOf('/node_modules/.vite/') !== -1) {
              maybeReload(src.split('/').pop() || 'vite asset');
            }
          },
          true,
        );
        window.addEventListener('load', function () {
          setTimeout(function () {
            try {
              sessionStorage.removeItem(KEY);
            } catch (_) {}
          }, 10000);
        });
      })();
    </script>
  </head>
  <body class="text-foreground flex min-h-screen flex-col antialiased">
    {showHeader ? (
      <SiteHeader
        client:load
        homeHref={homeHref}
        isProMember={isProMember}
        skipAuth={skipAuth}
        isAnonymous={isAnonymous}
        wideLayout={wideContent}
        zenModeToggle={adaptiveShell}
        userName={session?.user?.name ?? undefined}
        userEmail={session?.user?.email ?? undefined}
        userImage={session?.user?.image ?? undefined}
      />
    ) : null}
    <main
      class:list={[
        'mx-auto w-full flex-1 px-3',
        wideContent ? 'board-shell-wide' : 'board-shell',
        showHeader ? 'py-5 sm:py-6' : 'flex flex-col items-center justify-center py-10 sm:py-12',
      ]}
    >
      <slot />
    </main>
    <div class="site-footer-wrap mt-auto pt-8 sm:pt-10">
      <footer class="text-muted-foreground py-5 text-center text-xs leading-relaxed">
        <div class:list={['mx-auto px-3', wideContent ? 'board-shell-wide' : 'board-shell']}>
          <p>
            Breathe is produced by{' '}
            <a
              href={TAECHO_SITE_URL}
              class="text-foreground font-medium underline decoration-neutral-400/80 underline-offset-2 hover:opacity-90"
              rel="noopener noreferrer"
              target="_blank"
            >Taecho</a>{' '} - an agency for the AI era | {' '}
            <a
              href="/mit-license"
              class="text-foreground font-medium underline decoration-neutral-400/80 underline-offset-2 hover:opacity-90"
            >
              MIT License
            </a> - <a
              href={BREATHE_GITHUB_REPO_URL}
              class="text-foreground font-medium underline decoration-neutral-400/60 underline-offset-2 opacity-60 transition-opacity hover:opacity-100"
              rel="noopener noreferrer"
              target="_blank"
            >
              Contribute on GitHub
            </a>
          </p>
          <p class="text-pretty mt-4 text-[11px] leading-relaxed text-muted-foreground">
            {SITE_DESCRIPTION}
          </p>
        </div>
      </footer>
    </div>
    <Toaster client:only="react" />
  </body>
</html>
