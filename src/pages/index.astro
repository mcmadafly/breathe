---
import { TODO_BOARD_EXPAND_SHELL_CHARS } from '@/lib/todo-limits';
import { TodoBoardIsland, type TodoListRow, type TodoRow } from '@/components/todo-board-island';
import { listTodoListsForUser } from '@/lib/db/todo-lists';
import { listTodosForUser } from '@/lib/db/todos';

import BaseLayout from '../layouts/BaseLayout.astro';

const session = Astro.locals.session!;
const isPro = Astro.locals.isPro;
const isAnonymous = Astro.locals.isAnonymous;

const listRows = await listTodoListsForUser(session.user.id);
const initialLists: TodoListRow[] = listRows.map((r) => ({
  id: r.id,
  userId: r.userId,
  name: r.name,
  position: r.position,
  createdAt: r.createdAt,
  updatedAt: r.updatedAt,
}));

const rows = await listTodosForUser(session.user.id);
const initialTodos: TodoRow[] = rows.map((r) => ({
  id: r.id,
  userId: r.userId,
  title: r.title,
  body: r.body ?? '',
  listId: r.listId ?? '',
  position: r.position ?? 0,
  done: r.done,
  createdAt: r.createdAt,
  updatedAt: r.updatedAt,
}));

const todoBoardInitiallyWide = rows.some(
  (r) => r.title.length + (r.body?.length ?? 0) > TODO_BOARD_EXPAND_SHELL_CHARS,
);
---

<BaseLayout
  title="Breathe"
  session={session}
  isPro={isPro}
  isAnonymous={isAnonymous}
  wideContent
  adaptiveShell
  todoBoardInitiallyWide={todoBoardInitiallyWide}
>
  <TodoBoardIsland client:only="react" initialTodos={initialTodos} initialLists={initialLists} isPro={isPro} />
</BaseLayout>
