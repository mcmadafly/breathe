---
import { SignIn } from 'auth-astro/components';
import { getSession } from 'auth-astro/server';

import BaseLayout from '../layouts/BaseLayout.astro';
import { isSkipAuth } from '@/lib/auth/dev-session';

if (isSkipAuth()) return Astro.redirect('/app');

const session = await getSession(Astro.request);
if (session) return Astro.redirect('/app');
---

<BaseLayout title="Sign in · Scribbbles" session={null}>
  <div class="mx-auto max-w-sm space-y-8">
    <div class="space-y-2 text-center">
      <h1 class="font-heading text-2xl font-semibold tracking-tight">Sign in</h1>
      <p class="text-muted-foreground text-sm">Use a social account to sync your scribbbles.</p>
    </div>
    <div class="flex flex-col gap-3">
      <SignIn
        provider="google"
        class="bg-background text-foreground hover:bg-accent hover:text-accent-foreground inline-flex h-11 w-full items-center justify-center rounded-md border px-4 text-sm font-medium transition-colors"
      >
        Continue with Google
      </SignIn>
      <SignIn
        provider="github"
        class="bg-background text-foreground hover:bg-accent hover:text-accent-foreground inline-flex h-11 w-full items-center justify-center rounded-md border px-4 text-sm font-medium transition-colors"
      >
        Continue with GitHub
      </SignIn>
    </div>
    <p class="text-muted-foreground text-center text-xs">
      By continuing you agree to our use of session cookies for authentication.
    </p>
  </div>
</BaseLayout>
