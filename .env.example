AUTH_SECRET=generate_with_openssl_rand_hex_32
AUTH_TRUST_HOST=true

# Set to "true" to skip OAuth and test todos as a fixed local user (remove for production).
SKIP_AUTH=

# Turso — https://turso.tech (local: file:./local.db). After schema changes run: npm run db:push (or db:push:force).
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# GitHub OAuth — callback: http://localhost:4321/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth — callback: http://localhost:4321/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
