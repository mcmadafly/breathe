---
import { SignIn } from '@clerk/astro/components';

import BaseLayout from '../../layouts/BaseLayout.astro';
import { isSkipAuth } from '@/lib/auth/dev-session';

if (isSkipAuth()) return Astro.redirect('/breathe');

const { userId } = Astro.locals.auth();
if (userId) return Astro.redirect('/breathe');
---

<BaseLayout title="Sign in · Breathe" session={null}>
  <div class="mx-auto flex w-full max-w-md justify-center py-4">
    <SignIn path="/sign-in" routing="path" signUpUrl="/sign-up" />
  </div>
</BaseLayout>
