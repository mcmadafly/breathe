# Clerk — https://dashboard.clerk.com → API Keys (enable Google/GitHub/etc. under SSO connections)
PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Turso — https://turso.tech (create a database; use token for hosted, omit for file URLs)
# Local SQLite file (no token):
#   TURSO_DATABASE_URL=file:./local.db
# Hosted Turso:
#   TURSO_DATABASE_URL=libsql://your-db.turso.io
#   TURSO_AUTH_TOKEN=...
#
# Production (Cloudflare Worker): use `libsql://…` only — `file:` does not work on the edge.
TURSO_DATABASE_URL=file:./local.db
TURSO_AUTH_TOKEN=

# Turso Sync (@tursodatabase/sync) — Node / Docker / VPS only — NOT Cloudflare Workers (needs durable disk).
# Requires `TURSO_DATABASE_URL=libsql://...`, `TURSO_AUTH_TOKEN`, a local filesystem path below, and enabling the flag:
# TURSO_USE_SYNC=true
# TURSO_SYNC_PATH=.data/turso-sync.db

# Set to "true" to bypass Clerk and use a fixed dev user (local only; remove for production).
SKIP_AUTH=
# Set to "true" to force Pro features in the app for local testing.
FORCE_PRO=

#
# --- Cloudflare Worker (`wrangler.jsonc` name default **breathe**) — runtime env ---
# Production URL may be https://spirare.io — worker script name must match `wrangler.jsonc` → `name`.
#
# Moving from Pages? Dashboard env does **not** carry over. Set everything again on the **Worker**
# (same names as before), or use bulk upload below.
#
# Minimum for a working site (todos + Clerk + Turso):
#   · TURSO_DATABASE_URL — libsql://… (edge cannot use file:)
#   · TURSO_AUTH_TOKEN — Turso token (hosted DB)
#   · PUBLIC_CLERK_PUBLISHABLE_KEY — pk_…
#   · CLERK_SECRET_KEY — sk_…
#
# Optional (upgrade / Stripe): STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET, STRIPE_PRICE_PRO_MONTHLY,
#   STRIPE_PRICE_PRO_LIFETIME
#
# Dashboard: Workers & Pages → Workers → **breathe** → Settings → Variables and Secrets
# Astro/server reads Worker `env` at request time via `getEnv` / bindings (not only build-time).
#
# Fastest: put KEY=value lines in gitignored `cf-worker.secrets.env`, then:
#   npm run build && npm run cf:secret:bulk
# (`wrangler versions secret bulk` avoids error 10214 when “latest” ≠ currently deployed.)
#
# Or one-by-one (prompts for value):
#   npx wrangler secret put TURSO_AUTH_TOKEN
#   npx wrangler secret put CLERK_SECRET_KEY
#   …
#
# If Cloudflare only created a new version, run `npm run deploy` (or promote it) so traffic uses those secrets.
#
# `keep_vars: true` in `wrangler.jsonc`: merged `vars: {}` from the Astro build does not wipe dashboard vars.
#
# Bindings: KV namespace binding **SESSION** (must match wrangler.jsonc). Clerk → Domains for your host.
#
# Publishable key must be present at `npm run build` time (e.g. CI secret) so the client bundle embeds it.
#
# Primary: `npm run deploy` → `astro build` + `wrangler deploy --config dist/server/wrangler.json`.
#
# Optional Pages bundle only: `npm run deploy:pages` (see `scripts/cloudflare-pages-bundle.mjs`; uses
# `CLOUDFLARE_PAGES_PROJECT` / `--project-name` for the Pages project, not the Worker name).
#
# --- GitHub Actions (Workers deploy), not .env ---
# CLOUDFLARE_API_TOKEN — include Workers Scripts → Edit (and KV if you use SESSION).
# CLOUDFLARE_ACCOUNT_ID — Account that owns the Worker.

# Stripe — https://dashboard.stripe.com/apikeys (secret key sk_… only — not pk_ publishable)
# Products: e.g. $1.99/mo subscription + $99 one-time. Each needs a Price in the Dashboard; copy the
# Price ID (starts with price_) into the vars below — never put raw dollar amounts here.
# https://docs.stripe.com/products-prices/manage-prices
# Webhooks: endpoint `https://spirare.io/api/stripe/webhook` (or your domain); subscribe at least to
# `checkout.session.completed` and `customer.subscription.deleted`.
# Customer portal: Dashboard → Settings → Billing → Customer portal (enable) — used for cancel / invoices on /upgrade.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Monthly/lifetime checkout: use Price IDs from each product's Pricing section (price_…), never Product IDs (prod_…).
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_LIFETIME=
